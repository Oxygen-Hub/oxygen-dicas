---
interface Props {
  ativo?: string;
  base: string;
}

const { ativo = 'Todas', base: baseProp } = Astro.props;
// Normaliza a base removendo a barra final, pra juntar caminhos sem barra dupla.
const base = baseProp.replace(/\/$/, '');
const home = base || '/';

const categorias = [
  { nome: 'Todas', slug: '' },
  { nome: 'Viagens', slug: 'viagens' },
  { nome: 'Content+', slug: 'content-plus' },
  { nome: 'IRL', slug: 'irl' },
];
---
<div class="filtros">
  {categorias.map(cat => {
    const href = cat.slug === '' ? home : `${base}/${cat.slug}`;
    const isActive = cat.nome === ativo;
    return (
      <a href={href} class={`filtro ${isActive ? 'is-active' : ''}`}>
        {cat.nome}
      </a>
    );
  })}
</div>
