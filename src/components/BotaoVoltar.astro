---
// Componente de navegação "voltar uma página".
// Lógica híbrida inteligente:
//   - Se a página anterior está DENTRO da mesma seção (fallbackHref) → vai pro fallback (pai)
//   - Se está FORA (home, busca, outra categoria) → history.back()
//   - Se não há referrer (link direto) → vai pro fallback
// Visual: botão inline + versão fixed que aparece ao rolar.
//
// Uso: <BotaoVoltar fallbackHref={`${base}/viagens`} label="Viagens" />

export interface Props {
  fallbackHref: string;
  label: string;
}

const { fallbackHref, label } = Astro.props;
---

<!-- Placeholder pra reservar espaço no fluxo normal da página -->
<div class="botao-voltar-placeholder">
  <a
    href={fallbackHref}
    class="botao-voltar botao-voltar--inline"
    data-fallback={fallbackHref}
    aria-label={`Voltar para ${label}`}
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="19" y1="12" x2="5" y2="12"/>
      <polyline points="12 19 5 12 12 5"/>
    </svg>
    <span>Voltar para {label}</span>
  </a>
</div>

<!-- Versão fixa que aparece ao rolar -->
<div class="botao-voltar-fixed" data-fixed-wrap>
  <a
    href={fallbackHref}
    class="botao-voltar"
    data-fallback={fallbackHref}
    aria-label={`Voltar para ${label}`}
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="19" y1="12" x2="5" y2="12"/>
      <polyline points="12 19 5 12 12 5"/>
    </svg>
    <span>Voltar para {label}</span>
  </a>
</div>

<style>
  .botao-voltar-placeholder {
    margin: 24px 0 8px;
  }

  /* Versão fixa: gruda na viewport */
  .botao-voltar-fixed {
    position: fixed;
    top: 80px; /* abaixo do header */
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease, top 0.25s ease;
  }

  .botao-voltar-fixed.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  /* Ajuste em telas largas: alinha ao container */
  @media (min-width: 1024px) {
    .botao-voltar-fixed {
      left: max(50%, calc(50% - 540px));
      transform: translateX(0);
    }
  }

  .botao-voltar {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px 8px 12px;
    border: 1px solid var(--oxy-coral, #e85a4f);
    border-radius: 999px;
    background: var(--oxy-cream, #fcf5ef);
    color: var(--oxy-coral, #e85a4f);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.15s ease;
    cursor: pointer;
    line-height: 1;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .botao-voltar:hover,
  .botao-voltar:focus-visible {
    background: var(--oxy-coral, #e85a4f);
    color: #fff;
    transform: translateX(-2px);
    box-shadow: 0 4px 12px rgba(232, 90, 79, 0.25);
  }

  .botao-voltar svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .botao-voltar span {
    white-space: nowrap;
  }
</style>

<script>
  // Lógica híbrida de clique
  document.querySelectorAll('.botao-voltar').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      const link = btn as HTMLAnchorElement;
      const fallback = link.getAttribute('data-fallback') || '/';
      const referrer = document.referrer;

      // Sem referrer (link direto, abas nova, etc) → deixa o href fallback funcionar
      if (!referrer) return;

      try {
        const referrerUrl = new URL(referrer);
        const sameSite = referrerUrl.origin === window.location.origin;

        // Referrer de fora do site → deixa o href fallback funcionar (não previne)
        if (!sameSite) return;

        // Normaliza paths (remove trailing slash pra comparação)
        const referrerPath = referrerUrl.pathname.replace(/\/$/, '');
        const fallbackPath = new URL(fallback, window.location.origin).pathname.replace(/\/$/, '');

        // Se o referrer começa com o fallback path, significa que está navegando
        // dentro da mesma seção (ex: /irl/festival/ → /irl/evento/) — vai pro pai
        // Caso contrário (veio de home, busca, outra categoria) → history.back()
        if (referrerPath.startsWith(fallbackPath) && referrerPath !== fallbackPath) {
          // Está dentro da mesma seção → vai pro fallback (href padrão funciona)
          return;
        } else {
          // Veio de fora da seção → volta no histórico
          e.preventDefault();
          window.history.back();
        }
      } catch (err) {
        // Erro parseando URL → deixa o href padrão funcionar
        return;
      }
    });
  });

  // Mostra o botão fixo quando o botão inline sai da tela
  const placeholder = document.querySelector('.botao-voltar-placeholder');
  const fixedWrap = document.querySelector('[data-fixed-wrap]');

  if (placeholder && fixedWrap) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) {
            fixedWrap.classList.add('is-visible');
          } else {
            fixedWrap.classList.remove('is-visible');
          }
        });
      },
      { threshold: 0 }
    );

    observer.observe(placeholder);
  }
</script>
