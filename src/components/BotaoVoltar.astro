---
// Componente de navegação "voltar uma página".
// Usa history.back() do browser (volta pra página anterior real)
// e cai num fallback (href) se a pessoa chegou via link direto.
// Fica STICKY: gruda no topo da tela quando a pessoa rola.
//
// Uso: <BotaoVoltar fallbackHref={`${base}/viagens`} label="Viagens" />

export interface Props {
  fallbackHref: string;
  label: string;
}

const { fallbackHref, label } = Astro.props;
---

<div class="botao-voltar-wrap">
  <a
    href={fallbackHref}
    class="botao-voltar"
    data-fallback={fallbackHref}
    aria-label={`Voltar para ${label}`}
  >
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="19" y1="12" x2="5" y2="12"/>
      <polyline points="12 19 5 12 12 5"/>
    </svg>
    <span>Voltar para {label}</span>
  </a>
</div>

<style>
  /* Wrapper fica sticky — gruda no topo ao rolar */
  .botao-voltar-wrap {
    position: sticky;
    top: 0;
    z-index: 50;
    margin: 0 -16px 8px;
    padding: 16px 16px 12px;
    background: linear-gradient(
      to bottom,
      var(--oxy-cream, #fcf5ef) 0%,
      var(--oxy-cream, #fcf5ef) 85%,
      rgba(252, 245, 239, 0) 100%
    );
    pointer-events: none;
  }

  .botao-voltar {
    pointer-events: auto;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px 8px 12px;
    border: 1px solid var(--oxy-coral, #e85a4f);
    border-radius: 999px;
    background: var(--oxy-cream, #fcf5ef);
    color: var(--oxy-coral, #e85a4f);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.15s ease;
    cursor: pointer;
    line-height: 1;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
  }

  .botao-voltar:hover,
  .botao-voltar:focus-visible {
    background: var(--oxy-coral, #e85a4f);
    color: #fff;
    transform: translateX(-2px);
    box-shadow: 0 2px 8px rgba(232, 90, 79, 0.2);
  }

  .botao-voltar svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .botao-voltar span {
    white-space: nowrap;
  }
</style>

<script>
  // Intercepta o clique pra usar history.back() quando tiver histórico real.
  // Fallback pro href se chegou direto (sem histórico interno do site).
  document.querySelectorAll('.botao-voltar').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      const referrer = document.referrer;
      const sameSite = referrer && new URL(referrer).origin === window.location.origin;

      if (sameSite && window.history.length > 1) {
        e.preventDefault();
        window.history.back();
      }
    });
  });
</script>
