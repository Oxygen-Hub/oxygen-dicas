# URL completa do endpoint que valida o email do visitante contra a base de
# membros do Oxygen Club. É o deploy de produção do oxygen-admin, servido no
# domínio próprio https://admin.oxygenhub.com.br.
# Precisa ser configurada no ambiente de build (ex.: GitHub Pages / Actions),
# senão o portão de acesso não consegue validar emails. Aponte sempre para o
# endpoint de produção do oxygen-admin.
PUBLIC_ACCESS_API=https://admin.oxygenhub.com.br/api/dicas-access
